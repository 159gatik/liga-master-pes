rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES MAESTRAS ---
    function esAdminReal() {
      return request.auth != null && request.auth.uid == "o54QHjMwTNgo6xMcpewFdJbU4yW2";
    }

    function tieneRolAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }

    function mailVerificado() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // --- 1. USUARIOS ---
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId 
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rol', 'equipoId']);
      allow write: if esAdminReal();
    }

    // --- 2. CHAT (Unificado) ---
    match /chat/{messageId} {
      // PERMITIR LEER A TODOS: Esto evita el error en el Inicio
      allow read: if true; 
      // SOLO ESCRIBE SI ESTÁ LOGUEADO Y NO MIENTE CON SU UID
      allow create: if request.auth != null 
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.text.size() < 500;
      allow delete: if esAdminReal() || tieneRolAdmin();
    }

    // --- 3. EQUIPOS Y PLANTILLAS ---
    // --- 3. EQUIPOS Y PLANTILLAS ---
    match /equipos/{equipoId} {
      allow read: if true; 
      allow update: if request.auth != null; 
      allow create, delete: if esAdminReal();

      match /plantilla/{jugadorId} {
        allow read: if true;
        allow write: if esAdminReal();
      }

      // --- ESTA ES LA REGLA QUE DEBES MOVER AQUÍ ADENTRO ---
      match /movimientos/{movimientoId} {
        allow read: if request.auth != null;
        
        // Ahora equipoId sí es reconocido porque estamos dentro del match /equipos/{equipoId}
        allow create: if request.auth != null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.equipoId == equipoId ||
          tieneRolAdmin() || esAdminReal()
        );

        allow delete: if esAdminReal() || tieneRolAdmin();
      }
    }

    // --- 4. TORNEO Y CONFIGURACIÓN ---
    match /torneo/{docId} {
      allow read: if true; // Público para que todos vean fechas abiertas
      allow write: if esAdminReal();
    }

    // --- 5. POSTULACIONES ---
    match /postulaciones/{id} {
      // Solo permite postularse a usuarios logueados (opcional: mailVerificado())
      allow create: if request.auth != null;
      allow read: if request.auth != null && (esAdminReal() || resource.data.uid == request.auth.uid);
      allow delete: if esAdminReal() || tieneRolAdmin();
    }

    // --- 6. SOPORTE / FORO ---
    match /soporte_foro/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (request.auth.uid == resource.data.autorId || tieneRolAdmin() || esAdminReal());

      match /comentarios/{comentarioId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && 
          (request.auth.uid == resource.data.autorId || tieneRolAdmin() || esAdminReal());
      }
    }

    // --- 7. MERCADO ---
    match /{path=**}/solicitudes_mercado/{solicitud} {
       allow read, create: if request.auth != null;
       allow update, delete: if tieneRolAdmin() || esAdminReal();
    }
    match /reportes/{id} {
  allow read: if true; // CUALQUIERA puede ver los resultados
  allow create: if request.auth != null; // Solo logueados reportan
  allow delete: if esAdminReal();
}

match /disponibilidad/{id} {
  allow read: if true; // CUALQUIERA puede ver los horarios
  allow create, update: if request.auth != null;
  allow delete: if esAdminReal();
}

match /chats_privados/{chatId} {
  // Permitir si el UID del que consulta está dentro del ID del documento
  allow read, write: if request.auth != null && 
    (chatId.split('_')[0] == request.auth.uid || chatId.split('_')[1] == request.auth.uid);

  match /mensajes/{msgId} {
    // Si el usuario tiene acceso al chat padre, puede leer/escribir mensajes
    allow read, write: if request.auth != null;
  }
}
match /novedades/{id} {
  allow read: if true; // Cualquiera puede leer noticias
  allow create: if request.auth != null; // Solo DTs y Admin publican
  allow delete: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin');
}
match /pedidos_libres/{pedidoId} {
      // Todos pueden ver los fichajes aceptados, pero solo logueados ven los pendientes
      allow read: if request.auth != null;
      // Cualquier usuario logueado puede enviar una solicitud
      allow create: if request.auth != null;
      // Solo el Admin puede borrar o actualizar (aceptar/rechazar)
      allow update, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }

    // Reglas para la configuración del mercado (ventanas de fichajes)
    match /configuracion/mercado {
      // Todos los DTs necesitan leer si el mercado está abierto o cerrado
      allow read: if request.auth != null;
      // Solo el Admin puede abrir o cerrar el mercado
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
    }
    
    // Reglas para la colección global de jugadores libres (si la creaste aparte)
    match /jugadores_libres/{jugadorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // O ajustalo según quién deba escribir
    }
    
   match /partidos/{id} {
  allow read: if true; // Todos pueden ver el fixture
  allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin';
}
    
  }
}